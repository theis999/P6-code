@page
@model RegisterModel
@{
    ViewData["Title"] = "Register Board";
}
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]


<p>Enter a board name:</p>

<form id="ProductForm" method="post">
    Board Name:
    <input asp-for="name" name="name" />
    Product ID:
    <input asp-for="ProductID" id="ProductID" type="text" disabled />

    <input id="submit" type="submit" />
</form>

<script>
    // Get value from /URL/
    const searchParams = new URLSearchParams(window.location.search);
    // Print
    console.log("Product ID: " + searchParams.get("ProductID"));

    $(document).ready(function () {
        if (searchParams.get("ProductID") == null) {
            // Enable field if not found in URL
            //console.log("Product ID is null, enabling form");
            document.getElementById('ProductID').disabled = false;
        } else {
            // Set Product ID value to value from URL
            $('#ProductID').val(searchParams.get("ProductID"));
        }
    });
</script>



