# Required
PG_PASS={{ authentik_pg_pass }}
AUTHENTIK_SECRET_KEY={{ authentik_secret_key }}

# Optional: expose 80/443 instead of 9000/9443
{% if authentik_compose_port_http is defined %}
COMPOSE_PORT_HTTP={{ authentik_compose_port_http }}
{% endif %}
{% if authentik_compose_port_https is defined %}
COMPOSE_PORT_HTTPS={{ authentik_compose_port_https }}
{% endif %}

# Optional error reporting
# AUTHENTIK_ERROR_REPORTING__ENABLED=true